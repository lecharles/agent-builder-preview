<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Skills</title>
</head>
<body>
    <h1>My Skills</h1>
    <nav>
        <a href="/">Home</a> | <a href="/skills/new">Add a New Skill</a>
    </nav>
    <br>
    <% if (skills.length===0) { %>
        <p>You don't have any skills yet. Add one to get started.</p>
    <% } else { %>
        <ul>
            <% skills.forEach(skill=> { %>
                <li><a href="/skills/<%= skill._id %>"><%= skill.name %></a></li>
            <% }) %>
        </ul>
    <% } %>
</body>
</html>