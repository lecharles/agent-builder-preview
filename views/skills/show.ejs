<%- include('../partials/_header', { title: skill.name }) %>
<body>
    <%- include('../partials/_navbar') %>
    <main>
        <h1><%= skill.name %></h1>
        <p><%= skill.description %></p>
        <% if (skill.image) { %>
            <img src="<%= skill.image %>" alt="<%= skill.name %>">
        <% } %>
        <% if (skill.aiSummary) { %>
            <h3>AI Summary</h3>
            <p><%= skill.aiSummary %></p>
        <% } %>
        <% if (user._id===skill.createdBy.toString()) { %>
            <div class="actions">
                <a href="/skills/<%= skill._id %>/edit" class="btn">Edit Skill</a>
                <form action="/skills/<%= skill._id %>?_method=DELETE" method="POST">
                    <button type="submit" class="btn btn-danger">Delete Skill</button>
                </form>
            </div>
        <% } %>
    </main>
</body>
</html>