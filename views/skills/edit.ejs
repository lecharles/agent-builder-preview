<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit <%= skill.name %></title>
</head>
<body>
    <h1>Edit Skill</h1>
    <nav>
        <a href="/">Home</a> | <a href="/skills">My Skills</a> | <a href="/skills/<%= skill._id %>">Back to Skill</a>
    </nav>
    <br>
    <form action="/skills/<%= skill._id %>?_method=PUT" method="POST">
        <label for="name">Skill Name:</label><br>
        <input type="text" id="name" name="name" required value="<%= skill.name %>"><br><br>
    
        <label for="description">Description:</label><br>
        <textarea id="description" name="description" required><%= skill.description %></textarea><br><br>
    
        <label for="image">Image URL:</label><br>
        <input type="text" id="image" name="image" value="<%= skill.image ? skill.image : '' %>"><br><br>
    
        <button type="submit">Update Skill</button>
    </form>
</body>
</html>