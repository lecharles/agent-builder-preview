<%- include('../partials/_header', { title: 'Create a New Agent' }) %>
<body>
    <%- include('../partials/_navbar') %>
    <main>
        <h1>Create a New Agent</h1>
        <form action="/agents" method="POST">
            <label for="name">Agent Name:</label>
            <input type="text" id="name" name="name" required>

            <label for="description">Description:</label>
            <textarea id="description" name="description"></textarea>

            <label for="personalityPrompt">Personality Mode:</label>
            <select id="personalityPrompt" name="personalityPrompt">
                <% ['role-play', 'assistant', 'coaching', 'customer-care'].forEach(mode => { %>
                    <option value="<%= mode %>"><%= mode %></option>
                <% }) %>
            </select>

            <label for="customPersonality">Custom Personality Notes:</label>
            <textarea id="customPersonality" name="customPersonality"></textarea>

            <fieldset>
                <legend>Load Skills:</legend>
                <% if (skills.length === 0) { %>
                    <p>No skills created yet. <a href="/skills/new">Create a skill first.</a></p>
                <% } else { %>
                    <% skills.forEach(skill => { %>
                        <label>
                            <input type="checkbox" name="skills" value="<%= skill._id %>"><%= skill.name %>
                        </label>
                    <% }) %>
                <% } %>
            </fieldset>

            <label for="status">Status:</label>
            <select id="status" name="status">
                <option value="off">Off</option>
                <option value="on">On</option>
            </select>

            <button type="submit">Create Agent</button>
        </form>
    </main>
</body>
</html>