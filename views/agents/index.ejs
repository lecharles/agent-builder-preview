<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Agents</title>
</head>

<body>
    <h1>My Agents</h1>
    <nav>
        <a href="/">Home</a> | <a href="/agents/new">Create a New Agent</a>
    </nav>
    <br>
    <% if (agents.length===0) { %>
        <p>You don't have any agents yet. Create one to get started.</p>
    <% } else { %>
        <ul>
            <% agents.forEach(agent=> { %>
                <li><a href="/agents/<%= agent._id %>"><%= agent.name %></a>— <%= agent.status %></li>
            <% }) %>
        </ul>
    <% } %>
</body>

</html>