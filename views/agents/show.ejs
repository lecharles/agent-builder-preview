<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= agent.name %></title>
</head>
<body>
    <h1><%= agent.name %></h1>
    <nav>
        <a href="/">Home</a> | <a href="/agents">My Agents</a>
    </nav>
    <br>
    <% if (agent.description) { %>
        <p><%= agent.description %></p>
    <% } %>
    
    <p><strong>Personality:</strong> <%= agent.personalityPrompt %></p>
    <p><strong>Status:</strong> <%= agent.status %></p>
    
    <% if (agent.customPersonality) { %>
        <p><strong>Custom Personality:</strong> <%= agent.customPersonality %></p>
    <% } %>
    
    <% if (agent.job) { %>
        <h3>Inferred Job</h3>
        <p><%= agent.job %></p>
    <% } %>
    
    <h3>Loaded Skills</h3>
    <% if (agent.skills.length === 0) { %>
        <p>No skills loaded.</p>
    <% } else { %>
        <ul>
            <% agent.skills.forEach(skill => { %>
                <li><%= skill.name %></li>
            <% }) %>
        </ul>
    <% } %>
    <br>
    <a href="/preview/<%= agent._id %>">Preview Agent</a><br><br>
    <a href="/agents/<%= agent._id %>/edit">Edit Agent</a>
    <form action="/agents/<%= agent._id %>?_method=DELETE" method="POST">
        <button type="submit">Delete Agent</button>
    </form>
</body>
</html>