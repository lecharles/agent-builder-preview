<%- include('../partials/_header', { title: 'Preview ' + agent.name }) %>
<body>
    <%- include('../partials/_navbar') %>
    <main>
        <h1>Preview: <%= agent.name %></h1>

        <form action="/preview/<%= agent._id %>" method="POST">
            <label for="question">Ask your agent a question:</label>
            <textarea id="question" name="question" required><%= question %></textarea>
            <button type="submit">Send</button>
        </form>

        <% if (response) { %>
            <div class="response-area">
                <h3>Response</h3>
                <p><%= response %></p>
            </div>
        <% } %>

        <details>
            <summary>Dev Mode: View System Prompt</summary>
            <pre><%= systemPrompt %></pre>
        </details>
    </main>
</body>
</html>